generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum CategoryType {
  CSR_ACTIVITY
  CHALLENGE
}

enum ChallengeStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  COMPLETED
  ARCHIVED
}

enum ChallengeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ComplianceIssueStatus {
  OPEN
  RESOLVED
}

enum UserRole {
  EMPLOYEE
  MANAGER
  ADMIN
  SUPER_ADMIN
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum RewardStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

// ─── Master Data Models ─────────────────────────────────

model Department {
  id                   String        @id @default(cuid())
  name                 String
  code                 String        @unique
  headId               String?  @unique
  parentDepartmentId   String?
  employeeCount        Int           @default(0)
  status               DepartmentStatus @default(ACTIVE)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  parentDepartment     Department?   @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments     Department[]  @relation("DepartmentHierarchy")
  head                 User?         @relation("DepartmentHead", fields: [headId], references: [id])
  users                User[]
  carbonTransactions   CarbonTransaction[]
  scores               DepartmentScore[]

  @@map("departments")
}

model Category {
  id        String       @id @default(cuid())
  name      String
  type      CategoryType
  status    DepartmentStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  challenges Challenge[]

  @@map("categories")
}

model EmissionFactor {
  id           String   @id @default(cuid())
  activityType String
  factorValue  Float
  unit         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  carbonTransactions CarbonTransaction[]

  @@map("emission_factors")
}

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  unlockRule  Json
  iconSlug    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userBadges UserBadge[]
}

model Reward {
  id             String       @id @default(cuid())
  name           String
  description    String
  pointsRequired Int
  stockCount     Int          @default(0)
  status         RewardStatus @default(ACTIVE)
  imageUrl       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  redemptions RewardRedemption[]
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  avatarUrl      String?
  role           UserRole @default(EMPLOYEE)
  departmentId   String
  totalXp        Int      @default(0)
  availablePoints Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  department              Department           @relation(fields: [departmentId], references: [id])
  headedDepartment        Department?          @relation("DepartmentHead")
  employeeParticipations  EmployeeParticipation[]
  challengeParticipations ChallengeParticipation[]
  ownedIssues             ComplianceIssue[]    @relation("IssueOwner")
  assignedIssues          ComplianceIssue[]    @relation("IssueAssignee")
  userBadges              UserBadge[]
  redemptions             RewardRedemption[]

  @@map("users")
}

// ─── Transactional Data Models ──────────────────────────

model CarbonTransaction {
  id                 String   @id @default(cuid())
  departmentId       String
  emissionFactorId   String
  quantity           Float
  calculatedEmissions Float
  sourceOperation    String
  notes              String?
  transactionDate    DateTime @default(now())
  createdAt          DateTime @default(now())

  department     Department     @relation(fields: [departmentId], references: [id])
  emissionFactor EmissionFactor @relation(fields: [emissionFactorId], references: [id])

  @@map("carbon_transactions")
}

model EmployeeParticipation {
  id              String         @id @default(cuid())
  userId          String
  activityId      String
  proofUrl        String?
  approvalStatus  ApprovalStatus @default(PENDING)
  pointsEarned    Int            @default(0)
  completionDate  DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("employee_participations")
}

model Challenge {
  id               String          @id @default(cuid())
  title            String
  categoryId       String
  description      String
  xpReward         Int
  difficulty       ChallengeDifficulty @default(MEDIUM)
  evidenceRequired Boolean         @default(false)
  deadline         DateTime
  status           ChallengeStatus @default(DRAFT)
  imageUrl         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  category       Category                @relation(fields: [categoryId], references: [id])
  participations ChallengeParticipation[]

  @@map("challenges")
}

model ChallengeParticipation {
  id             String         @id @default(cuid())
  challengeId    String
  userId         String
  progress       Int            @default(0)
  proofUrl       String?
  approvalStatus ApprovalStatus @default(PENDING)
  xpAwarded      Int            @default(0)
  submittedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  challenge Challenge @relation(fields: [challengeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([challengeId, userId])
  @@map("challenge_participations")
}

model ComplianceIssue {
  id          String                @id @default(cuid())
  auditId     String
  severity    Int
  description String
  ownerId     String
  assigneeId  String?
  dueDate     DateTime
  status      ComplianceIssueStatus @default(OPEN)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  owner    User  @relation("IssueOwner", fields: [ownerId], references: [id])
  assignee User? @relation("IssueAssignee", fields: [assigneeId], references: [id])

  @@map("compliance_issues")
}

model DepartmentScore {
  id                 String   @id @default(cuid())
  departmentId       String
  environmentalScore Float
  socialScore        Float
  governanceScore    Float
  totalScore         Float
  calculatedAt       DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id])

  @@map("department_scores")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  unlockedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model RewardRedemption {
  id          String   @id @default(cuid())
  userId      String
  rewardId    String
  pointsSpent Int
  status      String   @default("PENDING")
  redeemedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  reward Reward @relation(fields: [rewardId], references: [id])

  @@map("reward_redemptions")
}
